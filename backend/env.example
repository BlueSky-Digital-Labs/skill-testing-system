# Django REST + DRF Starter Environment Configuration
# Copy this file to .env and update the values for your environment

# Environment (local, dev, uat, prod)
DJANGO_ENV=dev

# Django settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# For Docker development (default):
DATABASE_URL=postgresql://postgres:postgres@db:5432/backend_dev

# For local development without Docker, comment out DATABASE_URL and use these:
# DB_NAME=backend_local
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# For production, use a managed database:
# DATABASE_URL=postgresql://username:password@your-db-host:5432/your_production_db

# CORS settings (update with your frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# JWT settings
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
SIMPLE_JWT_ROTATE_REFRESH_TOKENS=True
SIMPLE_JWT_BLACKLIST_AFTER_ROTATION=True
SIMPLE_JWT_UPDATE_LAST_LOGIN=True
SIMPLE_JWT_ALGORITHM=HS256

# Celery settings
# For Docker development (default):
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# For local development without Docker, use these:
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# For production, use external Redis:
# CELERY_BROKER_URL=redis://your-redis-host:6379/0
# CELERY_RESULT_BACKEND=redis://your-redis-host:6379/1

# Logging
DJANGO_LOG_LEVEL=DEBUG

# PostgreSQL Docker settings (only used by docker-compose)
POSTGRES_DB=backend_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: Email settings (for password reset, notifications, etc.)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=no-reply@example.test
FRONTEND_URL=http://localhost:3000
RESEND_INVITE_THROTTLE_SECONDS=3600
INVITATION_URL_EXPIRE_SECONDS=604800
# EMAIL_PROVIDER=SES uses AWS credentials below for outbound email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@yourdomain.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Optional: Superuser creation (for initial setup)
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=your-admin-password

# Certificate storage (S3)
CERTIFICATES_BUCKET=certificates-dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CERTIFICATE_PRESIGNED_URL_EXPIRES=3600

